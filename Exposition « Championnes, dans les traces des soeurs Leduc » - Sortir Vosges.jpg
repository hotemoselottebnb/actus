  .bloc-next-events .wrapper-masonry > * { width: 50%; float: left; clear: =
none; margin-bottom: 20px; padding: 0px 5px !important; }
  .bloc-next-events .wrapper-masonry > :nth-child(3n+1) { clear: none; }
  .bloc-next-events .wrapper-masonry > :nth-child(2n+1) { clear: left; }
}

@media screen and (max-width: 320px) {
  .bloc-next-events .wrapper-masonry > * { width: 100%; float: none; clear:=
 none; }
}

.bloc-next-events .btn { margin-top: 40px; }
